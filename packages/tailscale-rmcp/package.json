{
  "name": "tailscale-rmcp",
  "version": "0.1.4",
  "description": "Node launcher for the Tailscale Rust MCP server and rtailscale CLI for tailnet operations.",
  "license": "MIT",
  "homepage": "https://github.com/jmagar/rtailscale#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmagar/rtailscale.git",
    "directory": "packages/tailscale-rmcp"
  },
  "bugs": {
    "url": "https://github.com/jmagar/rtailscale/issues"
  },
  "bin": {
    "tailscale-rmcp": "bin/rtailscale.js",
    "rtailscale": "bin/rtailscale.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "README.md",
    "LICENSE*",
    "package.json"
  ],
  "scripts": {
    "prepack": "node scripts/sync-readme.js",
    "postinstall": "node scripts/install.js",
    "test": "node --test",
    "check": "node --check bin/rtailscale.js && node --check scripts/install.js && node --check lib/platform.js && node --check scripts/sync-readme.js && node --check scripts/check-package.js && node scripts/check-package.js",
    "prepublishOnly": "node scripts/check-package.js --release"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "rmcp",
    "rust",
    "tailscale",
    "tailnet",
    "vpn",
    "networking",
    "device-management",
    "homelab",
    "cli",
    "claude-code",
    "codex",
    "gemini",
    "automation",
    "oauth",
    "http-server"
  ],
  "mcpName": "ai.dinglebear/tailscale-rmcp",
  "binaryVersion": "0.1.4",
  "author": {
    "name": "dinglebear.ai",
    "url": "https://dinglebear.ai"
  }
}
