{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.dinglebear/tailscale-rmcp",
  "title": "Tailscale RMCP",
  "description": "Rust MCP server and CLI for Tailscale devices, users, keys, policies, and auth.",
  "version": "0.1.3",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://ts.tootie.tv/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer token for the tailscale-rmcp MCP endpoint.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "websiteUrl": "https://github.com/jmagar/tailscale-rmcp",
  "repository": {
    "url": "https://github.com/jmagar/tailscale-rmcp",
    "source": "github",
    "id": "1238227291"
  },
  "icons": [
    {
      "src": "https://avatars.githubusercontent.com/u/38927646?v=4",
      "mimeType": "image/png",
      "sizes": [
        "460x460"
      ],
      "theme": "dark"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "tailscale-rmcp",
      "version": "0.1.3",
      "runtimeHint": "npx",
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp",
          "description": "Run Tailscale RMCP over stdio.",
          "format": "string",
          "isRequired": true,
          "isSecret": false,
          "isRepeated": false
        }
      ],
      "environmentVariables": [
        {
          "name": "TAILSCALE_API_KEY",
          "description": "Tailscale API key.",
          "format": "string",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "TAILSCALE_RMCP_VERSION",
          "description": "Optional GitHub release tag override for the downloaded Tailscale RMCP binary.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "v0.1.3"
        },
        {
          "name": "TAILSCALE_RMCP_REPO",
          "description": "Optional GitHub owner/repo override for release asset downloads.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "jmagar/tailscale-rmcp",
          "placeholder": "jmagar/tailscale-rmcp"
        },
        {
          "name": "TAILSCALE_RMCP_RELEASE_BASE_URL",
          "description": "Optional release download base URL override.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "RUST_LOG",
          "description": "Tracing filter for Tailscale RMCP logs.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "info",
          "placeholder": "info"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "namespace": "ai.dinglebear",
      "dnsDomain": "dinglebear.ai",
      "distribution": {
        "npm": "tailscale-rmcp@0.1.3",
        "nodePackage": "tailscale-rmcp"
      },
      "buildInfo": {
        "version": "0.1.3",
        "repository": "https://github.com/jmagar/tailscale-rmcp"
      }
    }
  }
}
